# ===========================================
# CampusConnect - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=development
PORT=4000

# ===========================================
# Database (PostgreSQL)
# ===========================================
# For local Docker setup:
DATABASE_URL="postgresql://campusconnect:campusconnect_dev_password@localhost:5432/campusconnect?schema=public"

# For production (use your actual connection string):
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&sslmode=require"

# ===========================================
# Redis
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# JWT Authentication
# ===========================================
# IMPORTANT: Generate secure random strings for production!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="your-super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ===========================================
# Security
# ===========================================
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MAX_CONCURRENT_SESSIONS=3

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ===========================================
# CORS
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ===========================================
# Frontend URL
# ===========================================
FRONTEND_URL="http://localhost:3000"

# ===========================================
# Email (Resend)
# ===========================================
# Get your API key from https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="CampusConnect <noreply@campusconnect.app>"

# ===========================================
# File Storage (S3/Cloudflare R2)
# ===========================================
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="campusconnect"

# ===========================================
# AI Integration (Claude/Anthropic)
# ===========================================
ANTHROPIC_API_KEY=""

# ===========================================
# Payments (Razorpay)
# ===========================================
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ===========================================
# Logging
# ===========================================
LOG_LEVEL="debug"

# ===========================================
# Invitation
# ===========================================
INVITATION_EXPIRY_DAYS=7
